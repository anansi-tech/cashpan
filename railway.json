{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "npm ci && npm --prefix worker ci && npm --prefix worker run build"
  },
  "deploy": {
    "startCommand": "node worker/dist/index.js",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE"
  }
}
