# CashPan Autopilot worker — deployment env (Railway / Fly).
# Copy to worker/.env locally, or paste these keys into the platform's env UI.
#
# AGENT_SECRET_KEY is WORKER-ONLY. Never set it in the Next.js/Vercel env —
# the app only ever needs AGENT_ADDRESS (the public address) to mint the cap to.
#
# Generate a fresh agent key (prints a `suiprivkey1...` Bech32 string, the form
# the worker parses). Run from the repo root:
#   npx tsx -e "import{Ed25519Keypair}from'@mysten/sui/keypairs/ed25519';console.log(new Ed25519Keypair().getSecretKey())"
# Then boot the worker once — it logs the derived agent address — fund that
# address with ~2 SUI (the agent pays its own gas) and set the SAME address as
# AGENT_ADDRESS in the Vercel env.
AGENT_SECRET_KEY=

# Mongo — same cluster as the app (the worker reads autopilot-enabled vaults).
MONGODB_URI=

# QuickNode — same values as the app's env. The JSON-RPC URL is derived from
# SUI_GRAPHQL_URL (graphql path stripped); set SUI_RPC_URL only to override.
SUI_GRAPHQL_URL=
SUI_GRPC_TOKEN=
SUI_GRPC_AUTH_HEADER=

# Move package + venue. PACKAGE_ID is the ORIGINAL id (identifies types and
# events forever); PACKAGE_ID_LATEST is the newest id in the upgrade chain
# (used for moveCall targets).
PACKAGE_ID=
PACKAGE_ID_LATEST=
VENUE_ID=

# Coin config — must match the app exactly.
COIN_TYPE=
COIN_DECIMALS=6
COIN_SYMBOL=USD

# mainnet | testnet
NEXT_PUBLIC_SUI_NETWORK=mainnet

# PORT is optional — Railway/Fly inject it; the worker defaults to 8080 and
# serves /healthz there.
