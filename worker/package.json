{
  "name": "cashpan-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CashPan Autopilot worker \u2014 deterministic buffer/band rebalancing. No LLM.",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --external:@mysten/sui --external:mongoose --external:dotenv --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\"",
    "start:dist": "node dist/index.js"
  },
  "dependencies": {
    "@mysten/sui": "2.17.0",
    "@suilend/sdk": "3.0.4",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.4"
  }
}
