# ── Network ──────────────────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── On-chain IDs (written by: npm run setup) ─────────────────────────────────
PACKAGE_ID=0x
VENUE_ID=0x
VAULT_ID=0x
OWNER_CAP_ID=0x
AGENT_CAP_ID=0x

# ── Agent signing key (written by: npm run setup) ─────────────────────────────
# SECURITY: can ONLY call vault::rebalance(), bounded by per-tx and daily caps.
# Owner can revoke at any time. Never use the owner keypair here.
AGENT_PRIVATE_KEY=

# ── Coin config (written by: npm run setup) ──────────────────────────────────
COIN_TYPE=0x2::sui::SUI
COIN_DECIMALS=9
COIN_SYMBOL=SUI
NEXT_PUBLIC_COIN_DECIMALS=9
NEXT_PUBLIC_COIN_SYMBOL=SUI

# ── Agent rule parameters (human-decimal; setup writes defaults if missing) ───
# BUFFER: target liquid balance. BAND: dead-band around buffer.
BUFFER=50
BAND=5
INTERVAL_MS=300000

# ── Google OAuth (for zkLogin) ────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/auth/callback

# ── Shinami (Gas Station + zkLogin Prover) ────────────────────────────────────
SHINAMI_GAS_STATION_KEY=
SHINAMI_ZKLOGIN_KEY=

# ── Services ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cashpan
OPENAI_API_KEY=sk-...
