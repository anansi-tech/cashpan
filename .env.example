# ─── Chain / deploy (written by: npm run setup) ──────────────────────────────
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443  # standalone agent only; web path uses GraphQL
NEXT_PUBLIC_SUI_NETWORK=mainnet
PACKAGE_ID=0x
VENUE_ID=0x
COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
COIN_DECIMALS=6
COIN_SYMBOL=USD

# ─── GraphQL / gRPC provider (QuickNode) ─────────────────────────────────────
SUI_GRAPHQL_URL=https://<endpoint>.quiknode.pro/graphql
SUI_GRPC_TOKEN=<api-key>
SUI_GRPC_AUTH_HEADER=x-token

# ─── Suilend integration ──────────────────────────────────────────────────────
# LENDING_MARKET_ID and RESERVE_INDEX removed — now sourced from @suilend/sdk/client
P_TYPE=0xf95b06141ed4a174f239417323bde3f209b972f5930d8521ea38a52aff3a6ddf::suilend::MAIN_POOL
CTOKEN_TYPE=0xf95b06141ed4a174f239417323bde3f209b972f5930d8521ea38a52aff3a6ddf::reserve::CToken<0xf95b06141ed4a174f239417323bde3f209b972f5930d8521ea38a52aff3a6ddf::suilend::MAIN_POOL,0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC>

# ─── Auth / zkLogin / gas ─────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/auth/callback
SHINAMI_GAS_STATION_KEY=
SHINAMI_ZKLOGIN_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
MONGODB_URI=
OPENAI_API_KEY=sk-...
