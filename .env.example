# Network
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Published package ID (filled by setup script)
PACKAGE_ID=0x

# Vault shared object ID (filled by setup script)
VAULT_ID=0x

# YieldVenue shared object ID (filled by setup script)
VENUE_ID=0x

# Agent keypair — base64-encoded 32-byte seed (Sui Ed25519)
# SECURITY: this key can ONLY call rebalance(), bounded by caps.
# Owner can revoke at any time. Do not use the owner keypair here.
AGENT_PRIVATE_KEY=

# Coin type for this vault (e.g. "0x2::sui::SUI")
COIN_TYPE=0x2::sui::SUI

# Rebalance rule parameters (in MIST for SUI, or smallest unit for other coins)
BUFFER=1000000000
BAND=100000000

# Scheduler interval in milliseconds
INTERVAL_MS=300000
