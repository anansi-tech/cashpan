# ─── Chain / deploy ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=mainnet
PACKAGE_ID=0x
# Latest package in the upgrade chain (moveCall targets only; types/events keep PACKAGE_ID)
PACKAGE_ID_LATEST=
VENUE_ID=0x
COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
COIN_DECIMALS=6
COIN_SYMBOL=USD

# ─── GraphQL / gRPC provider (QuickNode) ─────────────────────────────────────
SUI_GRAPHQL_URL=https://<endpoint>.quiknode.pro/graphql
SUI_GRPC_TOKEN=<api-key>
SUI_GRPC_AUTH_HEADER=x-token

# ─── Suilend integration ──────────────────────────────────────────────────────
# LENDING_MARKET_ID, LENDING_MARKET_TYPE, RESERVE_INDEX — all sourced from @suilend/sdk/client

# ─── Auth / zkLogin / gas ─────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/auth/callback
SHINAMI_GAS_STATION_KEY=
SHINAMI_ZKLOGIN_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
MONGODB_URI=
OPENAI_API_KEY=sk-...

# ─── Coinbase CDP (Onramp) ────────────────────────────────────────────────────
# Secret API key pair from the CDP dashboard. CDP_APP_ID (project id) is kept
# for reference; the session-token flow only needs the key pair.
CDP_APP_ID=
CDP_API_KEY=
CDP_API_SECRET=
